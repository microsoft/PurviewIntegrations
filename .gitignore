# ----------------------------------------------------------------
# A comprehensive .gitignore for a TypeScript Node.js project
# ----------------------------------------------------------------

# Logs
# Logs and debug files should not be committed.
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Dependencies
# The node_modules directory contains all of the project's dependencies.
# It is installed on a per-machine basis and should never be in version control.
/node_modules

# Build output
# Only the ncc-bundled files are needed for the GitHub Action to run.
# All other tsc output in dist/ is ignored.
/dist/*
!/dist/index.js
!/dist/sourcemap-register.js
!/dist/licenses.txt

# TypeScript cache files
# These files are used by the TypeScript compiler to speed up compilation.
*.tsbuildinfo

# Environment variables
# Never commit secrets, API keys, or other sensitive environment variables.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*

# IDE / Editor configuration folders
# These settings are specific to your local development environment.
.vscode/
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/

# OS-specific files
# These files are generated by various operating systems and are not part of the source code.
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Test reports
# If you add testing with tools like Jest or Cypress, their output should be ignored.
/coverage
/reports