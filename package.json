{
  "name": "purview-github-action",
  "version": "1.0.0",
  "description": "GitHub Action for Microsoft Purview integration",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "package": "ncc build dist/index.js -o dist",
    "test": "jest --passWithNoTests",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "all": "npm run build && npm run package && npm run test"
  },
  "keywords": [
    "github",
    "action",
    "purview",
    "microsoft",
    "governance"
  ],
  "author": "Microsoft",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@actions/glob": "^0.6.1",
    "@azure/msal-node": "^5.1.0",
    "axios": "^1.13.6",
    "is-binary-path": "^3.0.0",
    "minimatch": "^10.2.4"
  },
  "devDependencies": {
    "@octokit/types": "^16.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@vercel/ncc": "^0.38.4",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
