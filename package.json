{
  "name": "purview-github-action",
  "version": "1.0.0",
  "description": "GitHub Action for Microsoft Purview integration",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "package": "ncc build dist/index.js -o dist",
    "test": "jest --passWithNoTests",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "all": "npm run build && npm run package && npm run test"
  },
  "keywords": [
    "github",
    "action",
    "purview",
    "microsoft",
    "governance"
  ],
  "author": "Microsoft",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@actions/glob": "^0.4.0",
    "@azure/msal-node": "^3.6.4",
    "axios": "^1.13.6",
    "is-binary-path": "^3.0.0",
    "minimatch": "^10.0.1"
  },
  "devDependencies": {
    "@types/axios": "^0.14.4",
    "@types/is-binary-path": "^2.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@vercel/ncc": "^0.38.1",
    "jest": "^30.0.5",
    "ts-jest": "^29.4.0",
    "typescript": "^5.3.0"
  }
}
