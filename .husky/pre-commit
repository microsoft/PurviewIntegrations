#!/usr/bin/env sh

# ── Pre-commit hook for GitHub Actions repo ──
# Ensures dist/ is always rebuilt and up-to-date before committing.

# Exit on any error
set -e

# 1. Run tests
echo "🧪 Running tests..."
npm test

# 2. Build TypeScript and package with ncc
echo "🔨 Building dist/..."
npm run build && npm run package

# 3. Stage only the bundled files needed by the action
for f in dist/index.js dist/sourcemap-register.js dist/licenses.txt; do
  if [ -f "$f" ] && ! git diff --quiet "$f" 2>/dev/null; then
    echo "📦 $f has changed — staging..."
    git add "$f"
  fi
done

echo "✅ dist/ is up-to-date."
